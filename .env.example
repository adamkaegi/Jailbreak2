# Optional local Langfuse tracing
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://localhost:3000

# Required for the gated google/gemma-2b base used by StrongREJECT.
HF_TOKEN=

# Slow CPU fallbacks are disabled unless explicitly requested.
STRONGREJECT_ALLOW_CPU=0
HARMBENCH_ALLOW_CPU=0
